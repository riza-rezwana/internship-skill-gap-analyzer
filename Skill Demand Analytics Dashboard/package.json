{
  "name": "skill-demand-analytics",
  "version": "1.0.0",
  "description": "Module 2 (Member 3): Skill Demand Analytics Dashboard",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "db:migrate": "npx prisma migrate dev --name init",
    "db:seed": "node prisma/seed.js",
    "db:studio": "npx prisma studio",
    "setup": "npm install && npx prisma generate && npx prisma migrate dev --name init && node prisma/seed.js"
  },
  "dependencies": {
    "@prisma/client": "^5.10.0",
    "express": "^4.18.2"
  },
  "devDependencies": {
    "nodemon": "^3.0.3",
    "prisma": "^5.10.0"
  },
  "prisma": {
    "seed": "node prisma/seed.js"
  }
}
