generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model certificate {
  id               Int      @id @default(autoincrement())
  studentName      String
  companyName      String
  certificateFile  String
  durationMonths   Int
  experienceRating Int
  createdAt        DateTime @default(now())
}

model student {
  id                    Int             @id @default(autoincrement())
  firstName             String
  lastName              String
  email                 String          @unique(map: "Student_email_key")
  password              String
  phone                 String?
  country               String?
  dateOfBirth           DateTime?
  gender                String?
  resume                String?
  universityName        String?
  degree                String?
  department            String?
  semester              String?
  cgpa                  String?
  graduationYear        String?
  experience            String?         @db.Text
  locationPreferences   String?         @db.Text
  sectorPreferences     String?         @db.Text
  additionalInformation String?         @db.Text
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt
  
  // FIX 1: Rename the relationship to 'skills' to match her code
  skills                studentSkill[] 
}

// FIX 2: Capitalize 'studentSkill' to match her code (prisma.studentSkill)
model studentSkill {
  id        Int     @id @default(autoincrement())
  name      String
  studentId Int
  student   student @relation(fields: [studentId], references: [id], onDelete: Cascade, map: "StudentSkill_studentId_fkey")

  @@index([studentId], map: "StudentSkill_studentId_fkey")
}