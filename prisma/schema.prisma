generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}
enum ApplicationStatus {
  APPLIED
  REVIEWED
  INTERVIEW_SCHEDULED
  REJECTED
}
model certificate {
  id               Int      @id @default(autoincrement())
  studentName      String
  companyName      String
  certificateFile  String
  durationMonths   Int
  experienceRating Int
  createdAt        DateTime @default(now())
}

model student {
  id                    Int            @id @default(autoincrement())
  firstName             String
  lastName              String
  email                 String         @unique(map: "Student_email_key")
  password              String
  phone                 String?
  country               String?
  dateOfBirth           DateTime?
  gender                String?
  resume                String?
  universityName        String?
  degree                String?
  department            String?
  semester              String?
  cgpa                  String?
  graduationYear        String?
  experience            String?        @db.Text
  locationPreferences   String?        @db.Text
  sectorPreferences     String?        @db.Text
  additionalInformation String?        @db.Text
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt
  skills          studentSkill[]
  applications          application[]
}

model company {
  id                      Int          @id @default(autoincrement())
  companyName             String
  email                   String       @unique(map: "Company_email_key")
  password                String
  registrationNumber      String?
  industrySector          String?
  companySize             String?
  companyDescription      String?      @db.Text
  companyWebsite          String?
  contactPersonName       String?
  designation             String?
  phoneNumber             String?
  officeAddress           String?      @db.Text
  registrationCertificate String?
  gstCertificate          String?
  createdAt               DateTime     @default(now())
  updatedAt               DateTime
  internship              internship[]
}

model internship {
  id                    Int           @id @default(autoincrement())
  companyId             Int
  title                 String
  department            String?
  location              String?
  workMode              String?
  durationMonths        Int?
  stipend               Float?
  roleDescription       String        @db.Text
  learningOutcomes      String?       @db.Text
  numberOfPositions     Int           @default(1)
  requiredSkills        String?       @db.Text
  minimumDegreeLevel    String?
  preferredFieldOfStudy String?
  minimumGpaPercentage  String?
  graduationYearRange   String?
  additionalPreferences String?       @db.Text
  applicationDeadline   DateTime?
  status                String        @default("ACTIVE")
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt
  company               company       @relation(fields: [companyId], references: [id], onDelete: Cascade, map: "Internship_companyId_fkey")
  applications          application[]

  @@index([companyId], map: "Internship_companyId_fkey")
}
model application {
  id                 Int               @id @default(autoincrement())
  studentId          Int
  internshipId       Int
  status             ApplicationStatus @default(APPLIED)
  interviewType      String?
  interviewDateTime  DateTime?
  interviewLocation  String?
  interviewMeetLink  String?
  interviewNote      String?
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt

  student            student           @relation(fields: [studentId], references: [id], onDelete: Cascade, map: "Application_studentId_fkey")
  internship         internship        @relation(fields: [internshipId], references: [id], onDelete: Cascade, map: "Application_internshipId_fkey")

  @@unique([studentId, internshipId], map: "Application_studentId_internshipId_key")
  @@index([studentId], map: "Application_studentId_fkey")
  @@index([internshipId], map: "Application_internshipId_fkey")
}
model studentSkill {
  id        Int     @id @default(autoincrement())
  name      String
  studentId Int
  student   student @relation(fields: [studentId], references: [id], onDelete: Cascade, map: "StudentSkill_studentId_fkey")

  @@index([studentId], map: "StudentSkill_studentId_fkey")
}