generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Certificate {
  id               Int      @id @default(autoincrement())
  studentName      String
  companyName      String
  certificateFile  String
  durationMonths   Int
  experienceRating Int
  createdAt        DateTime @default(now())
}

model Student {
  id                    Int            @id @default(autoincrement())
  firstName             String
  lastName              String
  email                 String         @unique
  password              String
  phone                 String?
  country               String?
  dateOfBirth           DateTime?
  gender                String?
  resume                String?
  universityName        String?
  degree                String?
  department            String?
  semester              String?
  cgpa                  String?
  graduationYear        String?
  experience            String?        @db.Text
  locationPreferences   String?        @db.Text
  sectorPreferences     String?        @db.Text
  additionalInformation String?        @db.Text
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt

  skills                StudentSkill[]
}

model StudentSkill {
  id        Int      @id @default(autoincrement())
  name      String
  studentId Int
  student   Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
}