# Local setup note:
# No external MySQL database is required anymore.
# Prisma is configured to use the included local SQLite file: prisma/dev.db
# You can run the app after npm install because the demo database is included.

# Optional. The chatbot works without this key by using local rule-based replies.
OPENAI_API_KEY=""

# Optional server port. Default is 3000.
# If 3000 is busy, the app automatically tries the next available port unless AUTO_PORT_FALLBACK=false.
PORT=3000
AUTO_PORT_FALLBACK=true
NODE_ENV="development"
