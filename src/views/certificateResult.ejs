<!DOCTYPE html>
<html>

<head>

<title>Certificate Result</title>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

<style>

.star{
font-size:28px;
color:gold;
}

</style>

</head>

<body>

<div class="container mt-5">

<div class="row justify-content-center">

<div class="col-md-6">

<div class="card shadow p-4 text-center">

<h3 class="mb-3">Certificate Published Successfully</h3>

<p><strong>Student:</strong> <%= certificate.studentName %></p>

<p><strong>Company:</strong> <%= certificate.companyName %></p>

<p><strong>Duration:</strong> <%= certificate.durationMonths %> months</p>

<h5 class="mt-3">Practical Experience Rating</h5>

<div>

<% for(let i=1;i<=5;i++){ %>

<% if(i<=certificate.experienceRating){ %>

<span class="star">★</span>

<% } else { %>

<span class="star text-secondary">☆</span>

<% } %>

<% } %>

</div>

<a class="btn btn-primary mt-3"
href="<%= certificate.certificateFile %>" target="_blank">

View Certificate

</a>

<div class="mt-3">

<a href="/certificates" class="btn btn-outline-primary">
Upload Another
</a>

<a href="/" class="btn btn-outline-secondary">
Home
</a>

</div>

</div>

</div>

</div>

</div>

</body>

</html>