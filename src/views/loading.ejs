<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Generating Rating</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <style>
    body {
      margin: 0;
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      background: linear-gradient(135deg, #4f46e5, #c7b0dc);
      color: white;
      font-family: Arial, sans-serif;
    }

    .loading-box {
      text-align: center;
      background: rgba(255, 255, 255, 0.08);
      padding: 40px 50px;
      border-radius: 18px;
      backdrop-filter: blur(6px);
      box-shadow: 0 8px 24px rgba(0,0,0,0.2);
    }

    .spinner {
      width: 55px;
      height: 55px;
      border: 6px solid rgba(255,255,255,0.3);
      border-top: 6px solid white;
      border-radius: 50%;
      animation: spin 1s linear infinite;
      margin: 20px auto 0;
    }

    @keyframes spin {
      100% { transform: rotate(360deg); }
    }
  </style>
</head>
<body>
  <div class="loading-box">
    <h2>Rating Calculating Automatically...</h2>
    <p class="mt-3">Please wait while we generate your practical experience rating.</p>
    <div class="spinner"></div>
  </div>

  <script>
    setTimeout(() => {
      window.location.href = "<%= redirectUrl %>";
    }, 2000);
  </script>
</body>
</html>