<%- include('partials/header') %>

<div class="portal-bg">
  <div class="portal-overlay"></div>

  <div class="portal-home-btn-wrap">
    <a href="/" class="portal-home-btn" title="Home">
      <span>⌂</span>
    </a>
  </div>

  <div class="portal-brand-left">Internship + Skill Gap Analyzer</div>

  <div class="container py-3">
    <%- include('partials/alerts') %>

    <div class="register-page-wrap">
      <div class="portal-page-heading text-center mb-3">
        <h1 class="portal-main-title">✦ Student Portal</h1>
        <p class="portal-main-subtitle">
          Register and get matched with your perfect internship opportunity
        </p>
      </div>

      <div class="register-shell">
        <div class="text-center mb-2">
          <h2 class="join-title">Join the Platform</h2>
          <p class="join-subtitle">Complete your registration to start your internship journey</p>
        </div>

        <div class="custom-step-bar mb-3">
          <div class="step-pill active">Personal Info</div>
          <div class="step-pill">Academic Details</div>
          <div class="step-pill">Preferences</div>
        </div>

        <form action="/student/register" method="POST" enctype="multipart/form-data" id="multiStepForm">

          <!-- STEP 1 -->
          <div class="form-step active">

            <div class="section-glass mb-4">
              <h4 class="section-heading">Resume Auto-fill</h4>
              <p class="section-subtext">
                Upload your resume and let AI extract your information automatically
              </p>

              <label class="resume-drop-box" for="resumeInput">
                <input type="file" id="resumeInput" name="resume" accept=".pdf" hidden>
  
                <div class="resume-icon">📄</div>
                <div class="resume-main-text">Drag Drop or Choose File to Upload</div>
                <div class="resume-sub-text">PDF Accepted</div>

                <div class="resume-file-bar">
                   <span id="resumeFileName">No file chosen</span>
                </div>
              </label>
            </div>

            <div class="row g-4">
              <div class="col-md-6">
                <label class="custom-label">First Name</label>
                <input type="text" name="firstName" class="form-control custom-input" placeholder="Enter your first name" required>
              </div>

              <div class="col-md-6">
                <label class="custom-label">Last Name</label>
                <input type="text" name="lastName" class="form-control custom-input" placeholder="Enter your last name" required>
              </div>

              <div class="col-md-6">
                <label class="custom-label">Email Address</label>
                <input type="email" name="email" class="form-control custom-input" placeholder="your.email@example.com" required>
              </div>

              <div class="col-md-6">
                <label class="custom-label">Phone Number</label>
                <input type="text" name="phone" class="form-control custom-input" placeholder="+880-xxxxxxxxxx">
              </div>

              <div class="col-md-4">
                <label class="custom-label">Country</label>
                <input type="text" name="country" class="form-control custom-input" placeholder="Enter country">
              </div>

              <div class="col-md-4">
                <label class="custom-label">Date of Birth</label>
                <input type="date" name="dateOfBirth" class="form-control custom-input">
              </div>

              <div class="col-md-4">
                <label class="custom-label">Gender</label>
                <select name="gender" class="form-select custom-input">
                  <option value="">Select gender</option>
                  <option>Male</option>
                  <option>Female</option>
                  <option>Other</option>
                </select>
              </div>

              <div class="col-md-6">
                <label class="custom-label">Password</label>
                <input type="password" name="password" class="form-control custom-input" placeholder="Enter password" required>
              </div>

              <div class="col-md-6">
                <label class="custom-label">Confirm Password</label>
                <input type="password" name="confirmPassword" class="form-control custom-input" placeholder="Confirm password" required>
              </div>
            </div>

            <div class="step-action-end mt-4">
              <button type="button" class="next-btn nav-btn-blue">Next</button>
            </div>
          </div>

          <!-- STEP 2 -->
          <div class="form-step">
            <div class="section-glass mb-4">
              <div class="row g-4">
                <div class="col-md-6">
                  <label class="custom-label">University / Institute Name</label>
                  <input type="text" name="universityName" class="form-control custom-input" placeholder="Enter your university name">
                </div>

                <div class="col-md-6">
                  <label class="custom-label">Degree</label>
                  <input type="text" name="degree" class="form-control custom-input" placeholder="e.g. BSc Computer Science">
                </div>

                <div class="col-md-6">
                  <label class="custom-label">Department</label>
                  <input type="text" name="department" class="form-control custom-input" placeholder="Enter your department">
                </div>

                <div class="col-md-6">
                  <label class="custom-label">Semester / Year</label>
                  <input type="text" name="semester" class="form-control custom-input" placeholder="e.g. 7th Semester">
                </div>

                <div class="col-md-6">
                  <label class="custom-label">CGPA</label>
                  <input type="text" name="cgpa" class="form-control custom-input" placeholder="e.g. 3.75">
                </div>

                <div class="col-md-6">
                  <label class="custom-label">Expected Graduation Year</label>
                  <input type="text" name="graduationYear" class="form-control custom-input" placeholder="Select year">
                </div>
              </div>
            </div>

            <div class="section-glass mb-4">
               <h4 class="section-heading">Experience</h4>
               <p class="section-subtext">Add your previous experience, projects, internships, or extracurricular work</p>

               <textarea
                 name="experience"
                 class="form-control custom-textarea"
                 rows="4"
                 placeholder="Describe your experience here..."
               ></textarea>
            </div>

            <div class="section-glass mb-4">
              <h4 class="section-heading">Skills & Competencies</h4>
              <p class="section-subtext">Add your technical and soft skills for better matching</p>

              <div class="skill-row">
                <input type="text" id="skillInput" class="form-control custom-input skill-main-input" placeholder="Enter a skill (e.g., Python, Marketing)">
                <button type="button" class="skill-add-btn" id="addSkillBtn">＋</button>
              </div>

              <input type="hidden" name="skills" id="skillsHidden">
              <div id="skillsList" class="mt-3 d-flex flex-wrap gap-2"></div>
            </div>

            <div class="step-action-between mt-4">
              <button type="button" class="prev-btn nav-btn-blue">Previous</button>
              <button type="button" class="next-btn nav-btn-blue">Next</button>
            </div>
          </div>

          <!-- STEP 3 -->
          <div class="form-step">
            <div class="section-glass mb-4">
              <div class="row g-4">
                <div class="col-12">
                  <label class="custom-label">Location Preferences</label>
                  <textarea
                    name="locationPreferences"
                    class="form-control custom-textarea"
                    rows="3"
                    placeholder="Dhaka, Remote, Chittagong..."
                  ></textarea>
                </div>

                <div class="col-12">
                  <label class="custom-label">Sector Preferences</label>
                  <textarea
                    name="sectorPreferences"
                    class="form-control custom-textarea"
                    rows="3"
                    placeholder="Choose industries you're interested in working with"
                  ></textarea>
                </div>

                <div class="col-12">
                  <label class="custom-label">Additional Information</label>
                  <textarea
                    name="additionalInformation"
                    class="form-control custom-textarea"
                    rows="5"
                    placeholder="Describe your career aspirations, specific interests, or any additional information that might help in matching..."
                  ></textarea>
                </div>
              </div>
            </div>

            <div class="step-action-between mt-4">
              <button type="button" class="prev-btn nav-btn-blue">Previous</button>
              <button type="submit" class="nav-btn-blue">Complete Registration</button>
            </div>
          </div>

        </form>
      </div>
    </div>
  </div>
</div>
<script>
  const resumeInput = document.getElementById('resumeInput');
  const resumeFileName = document.getElementById('resumeFileName');

  if (resumeInput) {
    resumeInput.addEventListener('change', function () {
      if (this.files && this.files.length > 0) {
        resumeFileName.textContent = this.files[0].name;
      } else {
        resumeFileName.textContent = 'No file chosen';
      }
    });
  }
</script>
<%- include('partials/footer') %>