<%- include('partials/header') %>

<div class="portal-bg">
  <div class="portal-overlay"></div>

  <div class="portal-home-btn-wrap">
    <a href="/" class="portal-home-btn" title="Home"><span>⌂</span></a>
  </div>

  <div class="portal-brand-left">Student<br>Portal</div>

  <div class="container py-4">
    <%- include('partials/alerts') %>

    <div class="portal-page-wrap">
      <div class="portal-page-heading text-center mb-4">
        <h1 class="portal-main-title"><%= internship.title %></h1>
        <p class="portal-main-subtitle">
          Internship details from <%= internship.company.companyName %>
        </p>
      </div>

      <div class="register-shell">
        <div class="dashboard-top-bar mb-4">
          <div>
            <h2 class="join-title mb-1"><%= internship.company.companyName %></h2>
            <p class="join-subtitle mb-0"><%= internship.location || 'Location not specified' %></p>
          </div>

          <div class="dashboard-top-actions">
            <a href="/student/internships" class="glass-btn">Back to Internships</a>
          </div>
        </div>

        <div class="row g-4">
          <div class="col-lg-8">
            <div class="section-glass mb-4">
              <h4 class="section-heading mb-3">Role Description</h4>
              <div class="dashboard-text-box"><%= internship.roleDescription %></div>
            </div>

            <div class="section-glass mb-4">
              <h4 class="section-heading mb-3">Learning Outcomes</h4>
              <div class="dashboard-text-box"><%= internship.learningOutcomes || 'Not specified' %></div>
            </div>

            <div class="section-glass">
              <h4 class="section-heading mb-3">Additional Preferences</h4>
              <div class="dashboard-text-box"><%= internship.additionalPreferences || 'Not specified' %></div>
            </div>
          </div>

          <div class="col-lg-4">
            <div class="section-glass mb-4">
              <h4 class="section-heading mb-3">Overview</h4>

              <div class="dashboard-info-list">
                <div class="info-row">
                  <span class="info-label">Work Mode</span>
                  <span class="info-value"><%= internship.workMode || 'N/A' %></span>
                </div>

                <div class="info-row">
                  <span class="info-label">Duration</span>
                  <span class="info-value"><%= internship.durationMonths || 'N/A' %> months</span>
                </div>

                <div class="info-row">
                  <span class="info-label">Stipend</span>
                  <span class="info-value">৳<%= internship.stipend || 0 %></span>
                </div>

                <div class="info-row">
                  <span class="info-label">Positions</span>
                  <span class="info-value"><%= internship.numberOfPositions || 1 %></span>
                </div>

                <div class="info-row">
                  <span class="info-label">Degree</span>
                  <span class="info-value"><%= internship.minimumDegreeLevel || 'N/A' %></span>
                </div>
              </div>
            </div>

            <div class="section-glass">
              <h4 class="section-heading mb-3">Requirements</h4>
              <div class="dashboard-text-box mb-3">
                <strong>Skills:</strong><br>
                <%= internship.requiredSkills || 'Not specified' %>
              </div>

              <div class="dashboard-text-box mb-3">
                <strong>Field of Study:</strong><br>
                <%= internship.preferredFieldOfStudy || 'Not specified' %>
              </div>

              <div class="dashboard-text-box mb-3">
                <strong>Minimum GPA:</strong><br>
                <%= internship.minimumGpaPercentage || 'Not specified' %>
              </div>

              <div class="dashboard-text-box">
                <strong>Graduation Year:</strong><br>
                <%= internship.graduationYearRange || 'Not specified' %>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<%- include('partials/footer') %>