{{!-- FILE: views/error.hbs --}}
<div class="container py-5 text-center">
  <div style="font-size:4rem;font-family:monospace;font-weight:800;color:#e5e7eb">
    {{#if code}}{{code}}{{else}}Error{{/if}}
  </div>
  <h3 class="fw-semibold mt-2">{{message}}</h3>
  <p class="text-muted mt-1" style="font-size:.9rem">Something went wrong.</p>
  <a href="/matching" class="btn btn-sm btn-primary mt-2">Back to Matching</a>
</div>
